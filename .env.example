# Frontend (Vite) — copy to story-app/.env.local
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_SITE_URL=http://localhost:5173
VITE_STRIPE_PRICE_ID=price_...
VITE_ASSETS_BASE_URL=https://your-r2-or-cdn.example.com

# Backend (API server / serverless) — copy to backend/.env or host env UI
CLERK_SECRET_KEY=sk_test_...
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require"

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="cfat_..."
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET=your-bucket-name
R2_PUBLIC_BASE_URL="http://localhost:5173"

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
SITE_URL=http://localhost:5173
